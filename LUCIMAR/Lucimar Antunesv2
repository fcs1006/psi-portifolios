      margin-bottom: 1.6rem;
    }
    .qs-title em { font-style: italic; color: var(--sage); }
    .qs-title-pessoa em { color: rgba(200,221,191,0.9); }

    .qs-p {
      font-size: 1rem;
      line-height: 1.87;
      color: rgba(246,244,240,0.68);
      margin-bottom: 1.1rem;
      max-width: 52ch;
      font-weight: 400;
      text-align: justify;
    }
    .qs-p-pessoa {
      color: rgba(246,244,240,0.65);
    }

    .qs-content .abordagem-pills {
      justify-content: flex-start;
      margin-top: 1.8rem;
    }

    /* ── Divisória ── */
    .qs-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      background: linear-gradient(to bottom, #111A19 0%, #141816 15%, #181514 35%, #221419 55%, #341820 75%, #4A1A23 100%);
      padding: 3rem 3rem;
      overflow: hidden;
    }
    .qs-divider::before, .qs-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(200,221,191,0.14));
    }
    .qs-divider::after {
      background: linear-gradient(to left, transparent, rgba(200,221,191,0.14));
    }
    .qs-div-center {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0 2.5rem;
      flex-shrink: 0;
      position: relative;
      z-index: 3;
    }
    .qs-div-circles {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
