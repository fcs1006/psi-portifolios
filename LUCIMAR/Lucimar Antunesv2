    /* ══════ QUEM SOU EU (unified) ══════ */
    .quem-sou {
      position: relative;
      isolation: isolate;
      overflow: hidden;
    }

    /* ── Metade Profissional ── */
    .qs-pro {
      padding: 5rem 3rem 4rem;
      background:
        radial-gradient(circle at 22% 16%, rgba(200,221,191,0.13), transparent 34%),
        #111A19;
      position: relative;
    }
    .qs-pro::before {
      content: "";
      position: absolute;
      inset: -12%;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 30%, rgba(200,221,191,0.12), transparent 32%),
