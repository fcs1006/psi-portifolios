    // ── Curva fluida passando pelos marcadores ──────────────────────────
    function buildFlowPath() {
      const svg  = document.getElementById('servicos-flow-svg');
      const path = document.getElementById('servicos-flow-path');
      if (!svg || !path) return;

      const markers = [...document.querySelectorAll('.servicos-list .servico-marker')];
      if (!markers.length) return;

      const listRect = svg.parentElement.getBoundingClientRect();
      const svgW     = listRect.width;
      const svgH     = listRect.height;

      svg.setAttribute('viewBox', `0 0 ${svgW} ${svgH + 200}`);

      // Centro X de todos os marcadores (sempre no meio do container)
      const cx = svgW / 2;

      // Coleta apenas o Y real de cada marcador
      const ys = markers.map(m => {
        const r = m.getBoundingClientRect();
        return r.top - listRect.top + r.height / 2;
      });

      // Amplitude do ondulado — proporcional à largura disponível de cada lado
      const amp = Math.min(svgW * 0.28, 160);

      // A curva começa no 1º marcador e sai da página após o último
      const startY = ys[0];
      const endY   = svgH + 180; // sai da página

      let d = `M ${cx.toFixed(2)} ${startY.toFixed(2)}`;

      // Entre marcadores — S-wave alternado
      for (let i = 0; i < ys.length - 1; i++) {
        const y1   = ys[i];
        const y2   = ys[i + 1];
        const midY = (y1 + y2) / 2;
        const sign = (i % 2 === 0) ? 1 : -1;
        const cpX  = cx + sign * amp;
        d += ` C ${cpX.toFixed(2)} ${(y1 + (midY - y1) * 0.6).toFixed(2)}, ${cpX.toFixed(2)} ${(y2 - (y2 - midY) * 0.6).toFixed(2)}, ${cx.toFixed(2)} ${y2.toFixed(2)}`;
      }

      // Último marcador → sai da página em linha reta
      const lastY = ys[ys.length - 1];
      d += ` C ${cx.toFixed(2)} ${(lastY + (endY - lastY) * 0.4).toFixed(2)}, ${cx.toFixed(2)} ${(lastY + (endY - lastY) * 0.7).toFixed(2)}, ${cx.toFixed(2)} ${endY.toFixed(2)}`;

      path.setAttribute('d', d);
    }

    // Executa após fontes e layout estabilizarem
    if (document.readyState === 'complete') {
      buildFlowPath();
    } else {
      window.addEventListener('load', buildFlowPath);
    }
    window.addEventListener('resize', buildFlowPath);
  </script>

