  <!-- NAV SCROLL STATE -->
  <script>
    (function () {
      const nav = document.querySelector('nav');
      if (!nav) return;
      let lastScrollY = window.scrollY;
      let ticking = false;

      const updateNav = () => {
        const currentScrollY = window.scrollY;
        const delta = currentScrollY - lastScrollY;
        const passedTop = currentScrollY > 140;

        nav.classList.toggle('is-scrolled', currentScrollY > 24);

        if (currentScrollY <= 24) {
          nav.classList.remove('is-hidden');
        } else if (passedTop && delta > 10) {
          nav.classList.add('is-hidden');
        } else if (delta < -8) {
          nav.classList.remove('is-hidden');
        }

        lastScrollY = currentScrollY;
        ticking = false;
      };

      updateNav();
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateNav);
          ticking = true;
        }
      }, { passive: true });
    })();
  </script>

  <!-- CANVAS ANIMATION — tons verde + vinho -->
  <script>
    (function () {
      const canvas = document.getElementById('bg-canvas');
      const ctx    = canvas.getContext('2d');
      let rafId = null;
      let running = true;

      function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
      resize();
      window.addEventListener('resize', resize);

      const blobs = [
        { x: 0.72, y: 0.22, r: 0.42, color: [123, 175, 110], speed: 0.00022, phase: 0    },
        { x: 0.18, y: 0.62, r: 0.38, color: [139,  37,  53], speed: 0.00018, phase: 2.1  },
        { x: 0.52, y: 0.78, r: 0.30, color: [168, 210, 155], speed: 0.00025, phase: 1.3  },
        { x: 0.28, y: 0.18, r: 0.26, color: [200, 221, 191], speed: 0.00020, phase: 3.7  },
        { x: 0.82, y: 0.70, r: 0.28, color: [180,  60,  80], speed: 0.00016, phase: 0.8  },
        { x: 0.42, y: 0.42, r: 0.20, color: [150, 200, 140], speed: 0.00030, phase: 5.0  },
      ];

      function draw(ts) {
        if (!running) return;
        const W = canvas.width, H = canvas.height;
        ctx.clearRect(0, 0, W, H);
        ctx.fillStyle = '#F6F4F0';
        ctx.fillRect(0, 0, W, H);

        blobs.forEach(b => {
          const ox = Math.sin(ts * b.speed + b.phase) * 0.12;
          const oy = Math.cos(ts * b.speed * 0.7 + b.phase + 1) * 0.10;
          const bx = (b.x + ox) * W;
          const by = (b.y + oy) * H;
          const br = b.r * Math.min(W, H);
          const [r, g, bl] = b.color;
          const grad = ctx.createRadialGradient(bx, by, 0, bx, by, br);
          grad.addColorStop(0,   `rgba(${r},${g},${bl},0.52)`);
          grad.addColorStop(0.5, `rgba(${r},${g},${bl},0.20)`);
          grad.addColorStop(1,   `rgba(${r},${g},${bl},0)`);
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.arc(bx, by, br, 0, Math.PI * 2);
          ctx.fill();
        });

        rafId = requestAnimationFrame(draw);
      }

      function start() {
        if (running) return;
        running = true;
        rafId = requestAnimationFrame(draw);
      }

      function stop() {
        running = false;
        if (rafId) cancelAnimationFrame(rafId);
        rafId = null;
      }

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stop();
        } else {
          start();
        }
      });

      rafId = requestAnimationFrame(draw);
    })();
  </script>

