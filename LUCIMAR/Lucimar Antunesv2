<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lucimar Antunes — Psicóloga</title>
  <template id="__bundler_thumbnail" data-bg-color="#F6F4F0">
    <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
      <rect width="400" height="300" fill="#F6F4F0"/>
      <!-- wine accent bar left -->
      <rect x="0" y="0" width="4" height="300" fill="#8B2535"/>
      <!-- green accent bar right -->
      <rect x="396" y="0" width="4" height="300" fill="#7BAF6E"/>
      <!-- photo placeholder shape -->
      <ellipse cx="290" cy="130" rx="70" ry="95" fill="#C8DDBF" opacity="0.5"/>
      <ellipse cx="290" cy="130" rx="55" ry="78" fill="#9DC18C" opacity="0.4"/>
      <!-- Psi symbol -->
      <text x="200" y="145" font-family="serif" font-size="90" font-weight="300" fill="#8B2535" opacity="0.18" text-anchor="middle">Ψ</text>
      <!-- name line -->
      <rect x="60" y="90" width="160" height="3" rx="2" fill="#8B2535" opacity="0.5"/>
      <rect x="60" y="105" width="120" height="3" rx="2" fill="#1A1714" opacity="0.2"/>
      <rect x="60" y="120" width="140" height="3" rx="2" fill="#1A1714" opacity="0.15"/>
      <rect x="60" y="135" width="100" height="3" rx="2" fill="#1A1714" opacity="0.1"/>
      <!-- CTA pill -->
      <rect x="60" y="165" width="110" height="28" rx="14" fill="#8B2535"/>
      <rect x="185" y="165" width="90" height="28" rx="14" fill="none" stroke="#8B2535" stroke-width="1.5"/>
      <!-- green dots -->
      <circle cx="60" cy="240" r="30" fill="#7BAF6E" opacity="0.15"/>
      <circle cx="340" cy="60" r="45" fill="#8B2535" opacity="0.08"/>
    </svg>
  </template>
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,600;1,14..32,300;1,14..32,400&family=Outfit:wght@300;400;500&display=swap"
    rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:     #1A1714;
      --mid:     #2E2830;
      --dust:    #6A5860;
      --sage:    #C8DDBF;
      --green:   #7baf6e;
      --wine:    #8B2535;
      --wine2:   #6A1A28;
      --cream:   #F6F4F0;
      --white:   #FDFCFA;
      --mist:    rgba(246,244,240,0.88);
      --gold:    #dcc796;
      --emerald: #002212;
      --noir:    #111a19;
    }

    html { scroll-behavior: smooth; overflow-x: hidden; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--cream);
      color: var(--ink);
      overflow-x: hidden;
    }

    #bg-canvas {
      position: fixed; inset: 0; z-index: 0;
      opacity: 0.82; pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 1;
      pointer-events: none; opacity: 0.035;
      background-image: url("data:image/svg+xml;base64,");
      background-size: 180px;
    }

    #ripple-overlay {
      position: fixed; inset: 0; z-index: 1;
      pointer-events: none; opacity: 0.16;
    }

    /* ══════ NAV ══════ */
    nav {
      position: fixed; top: 0.9rem; left: 50%; z-index: 200;
      width: min(1240px, calc(100% - 2.4rem));
      transform: translateX(-50%);
      opacity: 1;
      will-change: transform, opacity;
      padding: 1.05rem 2.4rem;
      display: flex;
      justify-content: center;
      align-items: center;
      background: rgba(246,244,240,0.32);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(40,65,57,0.1);
      border-radius: 999px;
      box-shadow: 0 10px 30px rgba(17,26,25,0.06);
      transition: transform .45s cubic-bezier(.22,.61,.36,1), opacity .32s ease, background .35s ease, border-color .35s ease, box-shadow .35s ease, padding .35s ease, backdrop-filter .35s ease, width .35s ease;
    }
    nav.is-scrolled {
      padding: 0.88rem 2.2rem;
      background: rgba(246,244,240,0.86);
      backdrop-filter: blur(22px);
      border-color: rgba(139,37,53,0.12);
      box-shadow: 0 16px 38px rgba(26,23,20,0.1);
    }
    nav.is-hidden {
      transform: translate(-50%, -155%);
      opacity: 0;
      pointer-events: none;
    }

    .logo {
      display: none;
    }

    .nav-links {
      list-style: none;
      display: flex;
      gap: 0.8rem;
      justify-content: center;
      align-items: center;
      margin: 0;
      padding: 0;
    }
    .nav-links a {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 8.2rem;
      padding: 0.65rem 1.2rem;
      border-radius: 100px;
      border: 1px solid rgba(40,65,57,0.16);
      background: rgba(40,65,57,0.04);
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--emerald);
      text-decoration: none;
      transition: color .2s, background .25s, border-color .25s, transform .25s;
    }
    .nav-links a::after {
      display: none;
    }
    .nav-links a:hover {
      color: var(--wine);
      background: rgba(139,37,53,0.08);
      border-color: rgba(139,37,53,0.22);
      transform: translateY(-1px);
    }
    nav.is-scrolled .nav-links a {
      background: rgba(139,37,53,0.08);
      border-color: rgba(139,37,53,0.22);
      color: var(--wine);
    }
    nav.is-scrolled .nav-links a:hover {
      background: var(--wine2);
      border-color: var(--wine2);
      color: var(--cream);
    }

    .nav-btn {
      min-width: 8.2rem;
      background: rgba(139,37,53,0.08); color: var(--wine);
      border: 1px solid rgba(139,37,53,0.22);
      padding: 0.65rem 1.6rem; border-radius: 100px; font-size: 0.78rem;
      text-decoration: none; transition: all .25s; font-weight: 500; letter-spacing: 0.04em;
    }
    nav.is-scrolled .nav-btn {
      background: var(--wine);
      color: var(--cream);
      border-color: var(--wine);
    }
    .nav-btn:hover {
      background: var(--wine2);
      color: var(--cream);
      border-color: var(--wine2);
      transform: translateY(-1px);
    }

    .nav-hamburger { display: none; }
    .mobile-menu { display: none; }

    /* ══════ HERO ══════ */
    .hero {
      min-height: 92svh;
      display: flex; align-items: center; justify-content: center;
      padding: 3rem 3rem 0.7rem;
      position: relative; z-index: 10;
      overflow: hidden;
      background:
        linear-gradient(rgba(246,244,240,0.58), rgba(246,244,240,0.66)),
        url("data:image/jpeg;base64,") center / cover no-repeat;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.72fr);
      align-items: end;
      gap: clamp(1.2rem, 2.6vw, 2.75rem);
      width: min(100%, 1240px);
    }

    .hero-left {
      display: flex; flex-direction: column; align-items: flex-start;
      width: min(100%, 780px); min-width: 0; text-align: left;
      position: relative; z-index: 2;
    }

    .hero-right {
      position: relative;
      justify-self: end;
      width: min(28vw, 380px);
      min-width: 260px;
      margin-top: 0.6rem;
      z-index: 2;
    }

    .hero-photo-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 0.72;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      pointer-events: none;
    }

    .hero-photo-wrap::before {
      content: "";
      position: absolute;
      inset: 11% 4% 10% 12%;
      border-radius: 42% 58% 46% 54% / 34% 40% 60% 66%;
      background:
        radial-gradient(circle at 38% 34%, rgba(200,221,191,0.58), transparent 34%),
        radial-gradient(circle at 68% 58%, rgba(139,37,53,0.18), transparent 38%),
        linear-gradient(160deg, rgba(40,65,57,0.16), rgba(246,244,240,0.04));
      filter: blur(14px);
      opacity: 0.92;
      z-index: 0;
    }

    .hero-photo-wrap::after {
      content: "";
      position: absolute;
      inset: 4% 10% 22% 2%;
      border-radius: 55% 45% 58% 42% / 46% 30% 70% 54%;
      background: radial-gradient(circle at 52% 48%, rgba(246,244,240,0.42), rgba(200,221,191,0.08) 52%, transparent 76%);
      filter: blur(10px);
      z-index: 0;
    }

    .hero-photo {
      position: relative;
      z-index: 1;
      width: 108%;
      height: 100%;
      object-fit: cover;
      object-position: 47% 8%;
      transform: scale(1.1);
      transform-origin: center top;
      border-radius: 40% 40% 8% 8% / 16% 16% 6% 6%;
      box-shadow: 0 28px 60px rgba(26,23,20,0.12);
      opacity: 0;
      animation: fadeUp .8s .28s ease forwards;
    }

    .hero-loop-object {
      position: absolute;
      top: 8.4rem;
      left: -1rem;
      width: min(60vw, 860px);
      aspect-ratio: 2.55;
      transform: rotate(0deg);
      opacity: 0.18;
      pointer-events: none;
      z-index: 1;
      filter: blur(0.5px);
      animation: loopObjectDrift 9s ease-in-out infinite alternate;
    }
    .hero-loop-object span {
      position: absolute;
      inset: 0;
      border-radius: 12% 88% 16% 84% / 54% 42% 58% 46%;
      transform-origin: 50% 54%;
      mix-blend-mode: multiply;
    }
    .hero-loop-object span:nth-child(1) {
      background: linear-gradient(8deg, rgba(20,94,58,0.62), rgba(132,197,134,0.3) 40%, rgba(8,82,47,0.54) 78%);
      box-shadow: inset 0 18px 30px rgba(5,64,34,0.42), inset 0 -18px 34px rgba(220,246,205,0.28);
      transform: rotate(-4deg) skewY(-5deg);
      animation: loopRibbonOne 7s ease-in-out infinite alternate;
    }
    .hero-loop-object span:nth-child(2) {
      inset: 12% 3% 18% 2%;
      background: linear-gradient(354deg, rgba(246,244,240,0.08), rgba(35,137,78,0.44) 48%, rgba(5,78,43,0.32));
      border: 1px solid rgba(226,244,210,0.2);
      transform: rotate(5deg) skewY(7deg);
      animation: loopRibbonTwo 8s ease-in-out infinite alternate;
    }
    .hero-loop-object span:nth-child(3) {
      inset: 38% 4% 42% 6%;
      background: linear-gradient(90deg, transparent, rgba(153,230,146,0.72) 46%, transparent 56%);
      border-top: 1px solid rgba(230,248,214,0.34);
      transform: rotate(-8deg);
      animation: loopRibbonThree 6s ease-in-out infinite alternate;
    }
    .hero-loop-object span:nth-child(4) {
      inset: 42% 2% 42% 2%;
      background: linear-gradient(90deg, rgba(2,78,42,0.36), rgba(153,230,146,0.6), rgba(2,78,42,0.38));
      transform: rotate(12deg);
      filter: blur(0.6px);
      animation: loopRibbonGlow 5.5s ease-in-out infinite alternate;
    }
    .hero-loop-object span:nth-child(5) {
      inset: -18% 42% 14% 18%;
      border-radius: 68% 32% 52% 48% / 44% 58% 42% 56%;
      background: radial-gradient(ellipse at 36% 58%, rgba(4,91,48,0.54), rgba(50,151,82,0.28) 44%, transparent 70%);
      border-left: 1px solid rgba(9,70,39,0.22);
      transform: rotate(16deg);
      filter: blur(0.25px);
      animation: loopLeafOne 8.5s ease-in-out infinite alternate;
    }
    .hero-loop-object span:nth-child(6) {
      inset: 34% 14% -18% 46%;
      border-radius: 36% 64% 46% 54% / 54% 42% 58% 46%;
      background: radial-gradient(ellipse at 48% 44%, rgba(3,86,48,0.6), rgba(42,147,80,0.3) 48%, transparent 72%);
      border-right: 1px solid rgba(9,70,39,0.24);
      transform: rotate(-18deg);
      filter: blur(0.2px);
      animation: loopLeafTwo 7.5s ease-in-out infinite alternate;
    }

    /* ══════ HERO TAG ══════ */
    .hero-tag {
      display: flex; align-items: center; gap: 0.75rem;
      font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--wine); margin-bottom: 1.55rem;
      opacity: 0; animation: fadeUp .7s .1s ease forwards;
    }
    .hero-tag::before, .hero-tag::after {
      content: ''; display: block; width: 2rem; height: 1px; background: var(--wine);
    }
    .hero-title {
      font-family: 'Cormorant', serif;
      font-size: clamp(3.65rem, 4.6vw, 5.35rem); font-weight: 300;
      line-height: 0.98; letter-spacing: -0.03em; margin-bottom: 0.85rem;
      text-align: left; opacity: 0; animation: fadeUp .7s .25s ease forwards;
      max-width: 11.5ch;
    }
    .hero-title .solid { color: var(--ink); display: block; }
    .hero-title .italic { font-style: italic; }
    .hero-title .vazada { -webkit-text-stroke: 1.5px var(--ink); color: transparent; display: block; }
    .hero-title .vazada-wine {
      -webkit-text-stroke: 1.5px var(--wine); color: transparent; display: block; font-style: italic;
    }
    .hero-title .hero-line {
      display: block;
      white-space: nowrap;
    }
    .hero-desc {
      font-size: 1.25rem; line-height: 1.68; color: var(--mid);
      max-width: 43rem; margin-bottom: 0.85rem; font-weight: 400;
      text-align: justify; opacity: 0; animation: fadeUp .7s .4s ease forwards;
    }
    .hero-crp {
      display: inline-flex; align-items: center; justify-content: center;
      width: fit-content; padding: 0.85rem 1.8rem;
      border: 1px solid rgba(26,23,20,0.2); border-radius: 100px;
      background: transparent;
      font-family: 'Cormorant', serif; font-size: 0.95rem; font-style: italic;
      letter-spacing: 0; text-transform: none;
      color: var(--mid); margin-bottom: 0;
      transition: all .3s;
      opacity: 0; animation: fadeUp .7s .5s ease forwards;
    }
    .hero-crp:hover { border-color: var(--wine); color: var(--wine); }

    /* Photo placeholder */
    .photo-placeholder {
      width: 100%; height: 100%;
      background: linear-gradient(160deg, #C8DDBF 0%, #A8C99A 40%, #8B2535 100%);
      display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
      padding-bottom: 2.5rem;
    }
    .photo-placeholder-icon {
      font-family: 'Cormorant', serif; font-size: 8rem; font-weight: 300;
      color: rgba(255,255,255,0.25); line-height: 1;
    }
    .photo-placeholder-text {
      font-family: 'Cormorant', serif; font-size: 1rem; font-style: italic;
      color: rgba(255,255,255,0.6); letter-spacing: 0.08em;
    }

    section { position: relative; z-index: 10; }

    .marquee-bar {
      position: relative; z-index: 10;
      width: 100%; overflow: hidden;
      background: var(--emerald); color: var(--gold);
      border-top: 1px solid rgba(26,23,20,0.08);
      border-bottom: 1px solid rgba(26,23,20,0.08);
    }
    .marquee-track {
      display: inline-flex; width: max-content;
      transform: translate3d(0, 0, 0);
      will-change: transform;
      animation: marqueeLoop 100s linear infinite;
    }
    .marquee-bar:hover .marquee-track { animation-play-state: paused; }
    .marquee-group {
      display: flex; align-items: center; flex-shrink: 0;
    }
    .marquee-item {
      display: inline-flex; align-items: center;
      padding: 1.35rem 2.6rem;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.22em; text-transform: uppercase;
      white-space: nowrap;
    }
    .marquee-item::after {
      content: "";
      width: 4px; height: 4px; margin-left: 2.6rem;
      border-radius: 50%; background: var(--wine2);
    }

    @keyframes marqueeLoop {
      from { transform: translate3d(0, 0, 0); }
      to { transform: translate3d(-50%, 0, 0); }
    }

    /* ══════ COMO POSSO AJUDAR ══════ */
    .principios {
      position: relative;
      padding: 5rem 3rem;
      background: var(--wine2); backdrop-filter: blur(4px);
      color: var(--cream); overflow: hidden;
      scroll-margin-top: 5rem;
    }
    .principios::before {
      content: "";
      position: absolute;
      top: -9rem;
      left: 50%;
      width: min(206vw, 2440px);
      height: 1450px;
      transform: translateX(-50%);
      background: url("data:image/png;base64,") center top / contain no-repeat;
      opacity: 0.17;
      pointer-events: none;
      z-index: 0;
    }
    .principios-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; }
    .principios-header { margin-bottom: 5rem; text-align: center; }
    .principios-header .label {
      font-size: 1.5rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.5rem; display: block;
    }
    .principios-header h2 {
      font-family: 'Cormorant', serif; font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 300; line-height: 1.1;
    }
    .principios-header h2 .vazada {
      -webkit-text-stroke: 1px rgba(200,221,191,0.45); color: transparent; font-style: italic;
    }
    .principios-header h2 .sublinhada {
      position: relative;
      display: inline-block;
      padding: 0 0.14em;
      text-decoration: none;
      isolation: isolate;
    }
    .principios-header h2 .sublinhada-text {
      position: relative;
      z-index: 1;
      color: var(--wine2);
      -webkit-text-stroke: 1px rgba(200,221,191,0.45);
    }
    .principios-header h2 .sublinhada::before,
    .principios-header h2 .sublinhada::after {
      content: "";
      position: absolute;
      z-index: 0;
      pointer-events: none;
    }
    .principios-header h2 .sublinhada::before {
      inset: 0.02em -0.16em -0.04em;
      border: 2px solid var(--gold);
      border-radius: 58% 42% 48% 52% / 46% 55% 45% 54%;
      transform: rotate(-3deg);
      opacity: 0.9;
    }
    .principios-header h2 .sublinhada::after {
      inset: 0.08em -0.1em 0;
      border: 1px solid var(--gold);
      border-radius: 46% 54% 57% 43% / 55% 42% 58% 45%;
      transform: rotate(2deg);
      opacity: 0.55;
    }

    .principios-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: clamp(1.25rem, 2.4vw, 2.25rem);
      position: relative;
      align-items: start;
      margin-top: 4rem;
      padding-top: 2.25rem;
      background: transparent;
      isolation: isolate;
    }
    .principio {
      min-height: 390px;
      padding: 2.4rem 2.1rem 2.25rem;
      background: linear-gradient(180deg, rgba(246,244,240,0.76) 0%, rgba(246,244,240,0.9) 28%, rgba(246,244,240,0.94) 100%);
      border: 1px solid rgba(220,199,150,0.42);
      border-radius: 8px;
      box-shadow: 0 24px 60px rgba(26,23,20,0.22);
      transition: transform .35s ease, background .35s ease, border-color .35s ease, box-shadow .35s ease;
      position: relative; overflow: visible;
    }
    .principio:nth-child(1) { margin-top: 2.5rem; }
    .principio:nth-child(3) { margin-top: 2.5rem; }
    .principio::before {
      content: attr(data-num); position: absolute; right: 1.5rem; top: 1rem;
      font-family: 'Cormorant', serif; font-size: 6rem; font-weight: 300;
      color: rgba(106,26,40,0.08); line-height: 1; pointer-events: none;
    }
    .principio > * { position: relative; z-index: 1; }
    .principio:hover {
      background: linear-gradient(180deg, rgba(246,244,240,0.82) 0%, rgba(246,244,240,0.95) 30%, rgba(246,244,240,0.98) 100%);
      border-color: rgba(220,199,150,0.78);
      box-shadow: 0 30px 70px rgba(26,23,20,0.28);
      transform: translateY(-8px);
    }
    .principio-tag {
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--wine); margin-bottom: 1.5rem; display: inline-flex; align-items: center; gap: 0.7rem;
    }
    .principio-tag::before {
      content: "";
      display: inline-block;
      width: 1.7rem;
      height: 1px;
      background: currentColor;
    }
    .principio h3 {
      font-family: 'Cormorant', serif; font-size: 2.5rem; font-weight: 300;
      margin-bottom: 1.25rem; line-height: 1.05; color: var(--wine2);
    }
    .principio h3 em { font-style: italic; }
    .principio p {
      font-size: 0.88rem; line-height: 1.8; color: rgba(26,23,20,0.68);
      font-weight: 400; margin-bottom: 1.5rem; text-align: justify;
    }
    .principio-phrase {
      font-family: 'Cormorant', serif; font-style: italic; font-size: 1.05rem;
      color: var(--wine2); border-top: 1px solid rgba(106,26,40,0.14);
      padding-top: 1.25rem;
    }

    .ajuda-intro { margin-bottom: 3.5rem; text-align: center; margin-left: auto; margin-right: auto; max-width: 960px; }
    .ajuda-intro p { font-size: 1.2rem; line-height: 1.82; color: rgba(200,221,191,0.78); }

    .ajuda-fechamento {
      margin-top: 2.75rem; padding: 2.5rem 0;
      border-top: 1px solid rgba(255,254,251,0.07);
      border-bottom: 1px solid rgba(255,254,251,0.07);
      text-align: center;
    }
    .ajuda-destaque {
      font-family: 'Cormorant', serif; font-size: clamp(1.4rem, 2.2vw, 1.8rem);
      font-style: italic; line-height: 1.55; color: rgba(200,221,191,0.95); margin-bottom: 1.5rem;
    }
    .ajuda-convite {
      font-size: 1rem; line-height: 1.82; color: rgba(200,221,191,0.6);
      font-weight: 400; margin-bottom: 0; text-align: center;
      max-width: 76ch; margin-left: auto; margin-right: auto;
    }
    .ajuda-btn {
