      align-items: center;
      justify-content: center;
      pointer-events: none;
      z-index: 0;
    }
    .qs-div-phrase {
      font-family: 'Cormorant', serif;
      font-style: italic;
      font-size: 1.05rem;
      color: rgba(200,221,191,0.45);
      white-space: nowrap;
      letter-spacing: 0.06em;
      position: relative;
      z-index: 1;
    }
    .qs-div-line { display: none; }

    /* ── Metade Pessoal ── */
    .qs-pessoa {
      padding: 4rem 3rem 5rem;
      background: #4A1A23;
      position: relative;
    }
    .qs-label-pessoa { color: rgba(246,244,240,0.5); border-bottom-color: rgba(246,244,240,0.18); }
    .qs-title-pessoa { color: rgba(246,244,240,0.94); }
    .qs-title-pessoa em { color: #C8DDBF; }
    .qs-p-pessoa { color: rgba(246,244,240,0.68); }
    .qs-content-pessoa .sobreeu-tags span {
      color: rgba(246,244,240,0.55);
      border-color: rgba(246,244,240,0.18);
    }
    .qs-content-pessoa .sobreeu-tags span:hover {
      color: rgba(246,244,240,0.9);
      border-color: rgba(246,244,240,0.45);
    }

    .qs-photo-pessoa {
      position: relative;
      width: 300px;
      flex-shrink: 0;
    }
    .qs-photo-shell-pessoa {
      position: relative;
      width: 100%;
    }
    .qs-photo-shell-pessoa .sobreeu-photo {
      width: 300px;
      height: 420px;
      object-fit: cover;
      object-position: center top;
      border-radius: 2px;
      display: block;
      filter: grayscale(12%) contrast(1.04);
    }
    .qs-photo-shell-pessoa .sobreeu-deco-arc {
      position: absolute;
      inset: -10px;
      border: 1px solid rgba(200,221,191,0.15);
      border-radius: 3px;
      pointer-events: none;
    }

    /* ══════ SOBRE (legacy — keep for photo shape) ══════ */
    .sobre {
      padding: 5rem 3rem;
      max-width: none;
      margin: 0;
      position: relative;
      isolation: isolate;
      overflow: hidden;
      background:
        radial-gradient(circle at 22% 16%, rgba(200,221,191,0.13), transparent 34%),
        radial-gradient(circle at 82% 74%, rgba(139,37,53,0.13), transparent 36%),
        #111A19;
    }
    .sobre::before {
      content: "";
      position: absolute;
      inset: -12%;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 30%, rgba(200,221,191,0.12), transparent 32%),
        radial-gradient(circle at 76% 20%, rgba(40,65,57,0.44), transparent 30%),
        radial-gradient(circle at 70% 84%, rgba(139,37,53,0.1), transparent 34%);
      filter: blur(24px);
      opacity: 0.82;
    }
    .sobre::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background: rgba(246,244,240,0.035);
      backdrop-filter: blur(14px);
    }
    .sobre-inner {
      display: grid; grid-template-columns: 1fr 1fr;
      grid-template-rows: auto 1fr; column-gap: 3.5rem; row-gap: 1.5rem; align-items: start;
      max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;
    }
    .sobre-inner > * { min-width: 0; }
    .sobre-photo-wrap {
      grid-column: 1; grid-row: 1 / 3; align-self: center;
      justify-self: end; position: relative; width: fit-content;
    }
    .sobre-photo-shell {
      position: relative;
      width: fit-content;
    }
    .sobre-photo-shell::before,
    .sobre-photo-shell::after {
      content: "";
      position: absolute;
      pointer-events: none;
    }
    .sobre-photo-shell::before {
      inset: 2.5rem -1.5rem -1.5rem 1.75rem;
      border-radius: 180px 180px 8px 8px;
      background: linear-gradient(145deg, rgba(40,65,57,0.72), rgba(200,221,191,0.12));
      z-index: -2;
    }
    .sobre-photo-shell::after {
      left: -1.25rem; bottom: 3rem; width: 42%; aspect-ratio: 1;
      border-radius: 50%;
      border: 1px solid rgba(200,221,191,0.22);
      z-index: -1;
    }
    .sobre-orbit {
      position: absolute;
      border-radius: 50%;
      border: 1px dashed rgba(200,221,191,0.12);
      pointer-events: none;
      z-index: 0;
      transform-origin: center;
      will-change: transform, opacity;
      animation: spinSlow 40s linear infinite;
    }
    .sobre-orbit-1 {
      width: 76%;
      aspect-ratio: 1;
      left: -16%;
      top: 10%;
      border-color: rgba(200,221,191,0.1);
    }
    .sobre-orbit-2 {
      width: 70%;
      aspect-ratio: 1;
      right: -16%;
      top: 6%;
      border-color: rgba(200,221,191,0.14);
    }
    .sobre-orbit-3 {
      width: 58%;
      aspect-ratio: 1;
      left: -5%;
      bottom: -2%;
      border-color: rgba(139,37,53,0.14);
    }
    .sobre-text-top { grid-column: 2; grid-row: 1; }
    .sobre-text-body { grid-column: 2; grid-row: 2; }

    .sobre-photo-main {
      width: 300px; height: 420px;
      border-radius: 180px 180px 8px 8px; overflow: hidden;
      border: 1px solid rgba(200,221,191,0.16);
      box-shadow: 0 28px 70px rgba(0,0,0,0.36);
      position: relative; z-index: 2;
    }
    .sobre-photo-main img {
      width: 100%; height: 100%; object-fit: cover; object-position: 46% top;
      transform: scale(1.31); transform-origin: top center;
    }

    .sobre-deco-ring {
      position: absolute; width: 58%; height: 48%; border-radius: 50%;
      border: 1.5px dashed rgba(200,221,191,0.2); bottom: -4%; right: -6%;
      animation: spinSlow 40s linear infinite;
      z-index: 0;
    }
    .sobre-text-top .eyebrow {
      font-family: 'Cormorant', serif;
      font-size: clamp(2.8rem, 4.6vw, 4.2rem);
      font-weight: 300;
      letter-spacing: 0.02em;
      text-transform: none;
      color: rgba(246,244,240,0.94);
      line-height: 0.95;
      margin-bottom: 1rem;
      display: block;
    }
    .sobre-text-top p {
      color: rgba(246,244,240,0.9);
      font-size: 1.32rem;
    }
    .sobre-text-top h2 {
      font-family: 'Cormorant', serif; font-size: clamp(1.5rem, 4vw, 3.5rem);
      font-weight: 300; line-height: 1.15; margin-bottom: 2rem;
    }
    .sobre-text-top h2 em { font-style: italic; }

    .sobre-text-body p {
      font-size: 1rem; line-height: 1.87; color: rgba(246,244,240,0.72);
      margin-bottom: 1.3rem; font-weight: 400; text-align: justify;
    }

    .sobre blockquote {
      margin: 2.5rem 0; padding: 1.75rem 2rem;
      border-left: 3px solid rgba(200,221,191,0.48);
      background: rgba(246,244,240,0.055);
      border-radius: 0 8px 8px 0;
      font-family: 'Cormorant', serif; font-style: italic;
      font-size: 1.15rem; line-height: 1.55; color: rgba(246,244,240,0.86); text-align: justify;
    }
    .sobre .sobre-text-quote {
      width: 100%;
      margin: 1.6rem 0 0;
      box-sizing: border-box;
      text-align: left;
    }

    .abordagem-pills {
      grid-column: 1 / -1;
      display: flex; flex-wrap: nowrap; justify-content: center;
      gap: 0.9rem; width: 100%; margin-top: 1.5rem;
      overflow: visible; padding-bottom: 0;
    }
    .abordagem-pill {
      flex: 0 0 auto;
      font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(246,244,240,0.84); background: rgba(200,221,191,0.075);
      border: 1px solid rgba(200,221,191,0.16);
      padding: 0.46rem 1rem; border-radius: 100px;
    }

    /* ══════ ABORDAGEM / FRAGMENTOS ══════ */
    .frases {
      padding: 5rem 3rem;
      position: relative;
      overflow: hidden;
      background:
        linear-gradient(rgba(246,244,240,0.58), rgba(246,244,240,0.66));
    }
    .frases::before {
      display: none;
    }
    .frases::after {
      display: none;
    }
    .frases-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
    .frases h2 {
      font-family: 'Cormorant', serif; font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 300; text-align: center; margin-bottom: 0.75rem;
      color: rgba(56,37,31,0.92);
    }
    .frases h2 em { font-style: italic; color: inherit; }
    .frases-sub {
      text-align: center; font-style: italic; font-family: 'Cormorant', serif;
      color: rgba(92,68,57,0.78); margin-bottom: 4rem; font-size: 1.1rem;
    }
    .frases-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .frase {
      background: linear-gradient(180deg, rgba(106,26,40,0.96) 0%, rgba(86,21,34,0.98) 100%);
      border: 1px solid rgba(246,244,240,0.12); border-radius: 8px;
      padding: 2.5rem; transition: all .35s;
      box-shadow: 0 18px 40px rgba(56,18,26,0.18);
    }
    .frase:hover {
      transform: translateY(-4px);
      box-shadow: 0 22px 56px rgba(56,18,26,0.24);
      border-color: rgba(246,244,240,0.2);
    }
    .frase p {
      font-family: 'Cormorant', serif; font-size: 1.2rem; font-style: italic;
      line-height: 1.65; color: rgba(246,244,240,0.92); margin-bottom: 1.25rem;
      font-weight: 400; text-align: justify;
    }
    .frase-concept {
      font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(232,217,193,0.78);
    }

    /* ══════ SERVIÇOS ══════ */
    .servicos {
      padding: 3.9rem 3rem 5.5rem;
      max-width: none;
      overflow: visible;
      width: 100%;
      margin: 0;
      position: relative;
      overflow: hidden;
      background:
        linear-gradient(rgba(246,244,240,0.9), rgba(246,244,240,0.92));
      border-radius: 0;
    }
    .servicos::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(106,26,40,0.07), rgba(139,37,53,0.02) 38%, rgba(246,244,240,0.02) 76%),
        radial-gradient(circle at 22% 24%, rgba(139,37,53,0.05), transparent 26%),
        radial-gradient(circle at 78% 72%, rgba(40,65,57,0.04), transparent 22%);
      opacity: 0.95;
      pointer-events: none;
    }
    .servicos::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 44%, rgba(139,37,53,0.03), transparent 32%),
        linear-gradient(180deg, rgba(246,244,240,0.04), rgba(106,26,40,0.015));
      pointer-events: none;
    }
    .servicos-inner {
      position: relative;
      z-index: 1;
      overflow: visible;
      max-width: 1080px;
      margin: 0 auto;
    }
    .servicos-top {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      justify-items: center;
      margin-bottom: 3rem;
    }
    .servicos h2 {
      font-family: 'Cormorant', serif;
      font-size: clamp(2.7rem, 5vw, 4.35rem);
      font-weight: 300;
      line-height: 1.02;
      margin: 0;
      text-align: center;
      color: rgba(59,38,31,0.92);
    }
    .servicos h2 em { font-style: italic; color: var(--wine); }
    .servicos-sub {
      font-size: 1.02rem;
      line-height: 1.78;
      white-space: nowrap;
      color: rgba(74,57,49,0.82);
      margin: 0;
      text-align: center;
      max-width: 54ch;
    }
    .servicos-list {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 980px;
      margin: 0 auto;
      padding: 0.85rem 0 0.35rem;
      overflow: visible;
    }
    .servicos-flow {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: calc(100% + 200px);
      z-index: 1;
      pointer-events: none;
      overflow: visible;
      -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 92%);
      mask-image: linear-gradient(to bottom, black 60%, transparent 92%);
    }

    .servicos-flow path {
      fill: none;
      stroke: rgba(139, 37, 53, 0.34);
      stroke-width: 1.2;
      vector-effect: non-scaling-stroke;
    }

    .servico {
      --marker-y: 2.55rem;
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
      min-height: 8rem;
      padding: 0;
      transition: transform .28s ease, opacity .28s ease;
      z-index: 1;
    }
    .servico:hover {
      transform: translateY(-2px);
    }
    .servico:nth-of-type(even) {
      margin-top: 0.18rem;
    }
    .servico:nth-of-type(1) { --marker-y: 2.45rem; }
    .servico:nth-of-type(2) { --marker-y: 2.45rem; }
    .servico:nth-of-type(3) { --marker-y: 2.45rem; }
    .servico:nth-of-type(4) { --marker-y: 2.45rem; }
    .servico:nth-of-type(5) { --marker-y: 2.45rem; }
    .servico:nth-of-type(6) { --marker-y: 2.45rem; }
    .servico-marker {
      position: absolute;
      left: 50%;
      top: var(--marker-y);
      width: 18px;
      height: 18px;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: var(--cream);
      border: 1px solid rgba(139, 37, 53, 0.25);
      z-index: 3;
    }

    /* Primeiro marcador — ponto de partida em destaque */
    .servico:nth-of-type(1) .servico-marker {
      width: 26px;
      height: 26px;
      border: 1.5px solid rgba(139, 37, 53, 0.55);
      box-shadow: 0 0 0 5px rgba(139, 37, 53, 0.08);
    }
    .servico:nth-of-type(1) .servico-marker::after {
      inset: 6px;
    }

    .servico-marker::after {
      content: "";
      position: absolute;
      inset: 5px;
      border-radius: 50%;
      background: var(--wine);
    }
    .servico-body {
      position: relative;
      grid-column: 1;
      justify-self: end;
      width: min(100%, 29rem);
      padding: 0.82rem 1rem 0.45rem 0;
      text-align: right;
    }
    .servico:nth-of-type(even) .servico-body {
      grid-column: 2;
      justify-self: start;
      padding: 0.82rem 0 0.45rem 1rem;
      text-align: left;
    }
    .servico:nth-of-type(1) .servico-body {
      padding-right: 1rem;
    }
    .servico:nth-of-type(5) .servico-body {
      padding-right: 1rem;
    }
    .servico:nth-of-type(5) h3 {
      font-size: clamp(1.52rem, 2.4vw, 1.95rem);
      white-space: normal;
    }
    .servico:nth-of-type(6) .servico-body {
      padding-left: 1rem;
    }
    .servico-body::before {
      content: "";
      display: block;
      width: 3.4rem;
      height: 1px;
      margin-bottom: 1rem;
      background: rgba(106,26,40,0.18);
    }
    .servico:nth-of-type(odd) .servico-body::before,
    .servico:nth-of-type(even) .servico-body::before {
      content: none;
    }
    .servico h3 {
      font-family: 'Cormorant', serif;
      font-size: clamp(1.52rem, 2.4vw, 1.95rem);
      font-weight: 300;
      margin-bottom: 0.5rem;
      color: rgba(59,38,31,0.97);
      line-height: 1.12;
      max-width: 18ch;
      white-space: normal;
    }
    .servico:nth-of-type(odd) h3,
    .servico:nth-of-type(odd) p {
      margin-left: auto;
    }
    .servico p {
      font-size: 0.98rem;
      line-height: 1.78;
      color: rgba(46,40,48,0.88);
      margin: 0;
      max-width: 32ch;
    }
    .servico:nth-of-type(odd) p {
      max-width: 31ch;
    }
    .servico:nth-of-type(even) p {
      max-width: 32ch;
    }
    .servico + .servico .servico-body {
      border-top: none;
    }

    /* ══════ MAS ESSA TAMBÉM SOU EU ══════ */
    .sobreeu {
      background: #2a2218;
      padding: 5rem 3rem 5.5rem;
      position: relative;
      overflow: hidden;
    }
    .sobreeu::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 70% 50%, rgba(200,221,191,0.07) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 10% 80%, rgba(139,37,53,0.08) 0%, transparent 60%);
      pointer-events: none;
    }
    .sobreeu-inner {
      position: relative;
      z-index: 1;
      max-width: 1080px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 5rem;
      align-items: center;
    }
    .sobreeu-eyebrow {
      color: var(--sage);
      opacity: 0.7;
      letter-spacing: 0.18em;
    }
    .sobreeu-title {
      font-family: 'Cormorant', serif;
      font-size: clamp(2.4rem, 4vw, 3.6rem);
      font-weight: 300;
      line-height: 1.1;
      color: var(--cream);
      margin: 0.6rem 0 1.8rem;
    }
    .sobreeu-title em {
      font-style: italic;
      color: var(--sage);
    }
    .sobreeu-p {
      font-size: 1rem;
      line-height: 1.82;
      color: rgba(246,244,240,0.72);
      margin-bottom: 1.1rem;
      max-width: 54ch;
    }
    .sobreeu-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 2rem;
    }
    .sobreeu-tags span {
      font-family: 'Outfit', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
