      filter: blur(24px);
      opacity: 0.82;
    }

    .qs-inner {
      display: grid;
      grid-template-columns: auto 1fr;
      column-gap: 3.5rem;
      align-items: center;
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .qs-inner-pessoa {
      grid-template-columns: 1fr auto;
    }

    .qs-label {
      display: inline-block;
      font-family: 'Cormorant', serif;
      font-size: 1.05rem;
      font-style: italic;
      letter-spacing: 0.06em;
      color: rgba(200,221,191,0.7);
      margin-bottom: 1rem;
      padding-bottom: 0.45rem;
      border-bottom: 1px solid rgba(200,221,191,0.25);
    }
    .qs-label-pessoa {
      color: rgba(139,37,53,0.75);
      border-bottom-color: rgba(139,37,53,0.25);
    }

    .qs-title {
